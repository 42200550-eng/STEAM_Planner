{
  "name": "react-example",
  "description": "URLAB STEAM Planner desktop controller",
  "author": "URLAB",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:windows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$conn = Get-NetTCPConnection -LocalPort 8787 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force }; npm.cmd run dev:windows:run\"",
    "dev:windows:run": "concurrently -k \"npm:dev:gateway\" \"npm:dev:desktop\"",
    "dev:desktop": "concurrently -k \"npm:dev\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:3000 && electron .",
    "dev:gateway": "node server/gateway.mjs",
    "dev:sim": "node server/udp-simulator.mjs",
    "build": "vite build",
    "build:desktop": "vite build && electron-builder --win nsis",
    "build:desktop:portable": "vite build && electron-builder --win portable",
    "dist:win": "npm run build:desktop",
    "dist:win:portable": "npm run build:desktop:portable",
    "preview": "vite preview",
    "clean": "rimraf dist release",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.urlab.steamplanner",
    "productName": "STEAM Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "win": {
      "executableName": "STEAM Planner",
      "target": [
        "nsis"
      ],
      "artifactName": "steam-planner-${version}-setup.${ext}",
      "icon": "A logo/public/urlab_logo_icon_official.svg",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
