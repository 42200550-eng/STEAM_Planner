# Local UDP Gateway settings for Robot Dog bridge.
# Frontend sends /api/udp-gateway -> gateway server -> UDP packets to robot endpoint.
# For real robot over Wi-Fi, set ROBOT_UDP_HOST to robot LAN IP (example: 192.168.4.1).
GATEWAY_PORT=8787
ROBOT_UDP_HOST="127.0.0.1"
ROBOT_UDP_PORT=9000
# UDP reply wait time from gateway before marking timeout.
ROBOT_UDP_RESPONSE_TIMEOUT_MS=600

# App watchdog tuning (optional, used by MonolithicDashboard runtime)
# Firmware watchdog timeout in milliseconds.
VITE_WATCHDOG_TIMEOUT_MS=1500
# App heartbeat interval in milliseconds.
VITE_WATCHDOG_HEARTBEAT_MS=300
# Heartbeat action for WiFi watchdog keepalive. Leave empty to disable autonomous heartbeat control.
# Supports fallback list by comma, for example: heartbeat,status (safe-only actions).
VITE_WATCHDOG_HEARTBEAT_ACTION=
# Serial link timeout used by desktop COM status monitor (ms).
VITE_SERIAL_LINK_TIMEOUT_MS=15000
# If true, UI link timeout warning is disabled (useful for firmware bring-up sessions).
VITE_DISABLE_LINK_TIMEOUT=false
# Serial mode is for provisioning/diagnostics only in protocol clean V3.
VITE_SERIAL_PROTOCOL_MODE=text
# Maximum time budget before app triggers fallback (ms).
VITE_WATCHDOG_FALLBACK_MS=3000
# If true, WiFi CONNECTED requires fresh UDP ACK. If false, fresh UDP forwarding is enough.
VITE_WIFI_STRICT_ACK=false
